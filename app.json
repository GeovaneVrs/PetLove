{
  "expo": {
    "name": "PetLove",
    "slug": "PetLove",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "splash": {
        "image": "./assets/icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "splash": {
        "image": "./assets/icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "O PetLove usa sua localização para mostrar a distância até os abrigos em Recife."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O PetLove acessa suas fotos para atualizar o perfil.",
          "cameraPermission": "O PetLove usa a câmera para tirar sua foto de perfil."
        }
      ]
    ]
  }
}
